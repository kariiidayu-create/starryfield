---
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments.astro';
import Reactions from '../../components/Reactions.astro';
import TOC from '../../components/TOC.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const cooking = await getCollection('cooking');
  return cooking.map(d => ({ params: { id: d.id }, props: { dish: d } }));
}

const { dish } = Astro.props;
const { Content, headings } = await render(dish);
const readingTime = getReadingTime(dish.body || '');
---

<Base title={dish.data.title}>
  <div class="article-layout">
    <article style="padding: 20px 0; max-width: 700px; flex: 1; min-width: 0;">
      <div class="post-header">
        <div class="post-meta" style="margin-bottom: 16px;">
          <span class="tag">{dish.data.tag}</span>
          <span>{dish.data.date}</span>
          <span class="reading-time">约 {readingTime} 分钟</span>
        </div>
        <h1 class="post-title">{dish.data.title}</h1>
        <p style="font-size: 15px; color: var(--text-dim); margin-top: 8px; font-style: italic;">{dish.data.note}</p>
      </div>
      <div style="margin-top: 24px;">
        <img src={dish.data.cover} alt={dish.data.title} style="width: 100%; border-radius: 2px; border: 1px solid rgba(0,255,245,0.1);" />
      </div>
      <div class="post-content" style="margin-top: 32px;">
        <Content />
      </div>
      <Reactions />
      <Comments />
      <div style="margin-top: 48px; padding-top: 24px; border-top: 1px dashed rgba(0,255,245,0.15);">
        <a href="/cooking" style="font-family: var(--pixel-font); font-size: 13px; color: var(--text-dim); text-decoration: none;">&larr; BACK TO COOKING</a>
      </div>
    </article>
    <TOC headings={headings} />
  </div>
</Base>
