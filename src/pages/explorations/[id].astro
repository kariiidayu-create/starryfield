---
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments.astro';
import Reactions from '../../components/Reactions.astro';
import Share from '../../components/Share.astro';
import TOC from '../../components/TOC.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('explorations');
  return posts.map(post => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = getReadingTime(post.body || '');
---

<Base title={post.data.title}>
  <div class="article-layout">
    <article style="padding: 20px 0; max-width: 700px; flex: 1; min-width: 0;">
      <div class="post-header">
        <div class="post-meta" style="margin-bottom: 16px;">
          <span class="tag">{post.data.tag}</span>
          <span>{post.data.date}</span>
          <span class="reading-time">约 {readingTime} 分钟</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
      </div>
      <div class="post-content">
        <Content />
      </div>
      <Share title={post.data.title} />
      <Reactions />
      <Comments />
      <div style="margin-top: 48px; padding-top: 24px; border-top: 1px dashed rgba(0,255,245,0.15);">
        <a href="/explorations" style="font-family: var(--pixel-font); font-size: 13px; color: var(--text-dim); text-decoration: none;">← BACK TO EXPLORATIONS</a>
      </div>
    </article>
    <TOC headings={headings} />
  </div>
</Base>
