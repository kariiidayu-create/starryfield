---
import Base from '../../layouts/Base.astro';
import PixelIcon from '../../components/PixelIcon.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = [
    ...(await getCollection('games')).map(c => ({ ...c, _collection: 'games' })),
    ...(await getCollection('explorations')).map(c => ({ ...c, _collection: 'explorations' })),
    ...(await getCollection('crafts')).map(c => ({ ...c, _collection: 'crafts' })),
    ...(await getCollection('drawings')).map(c => ({ ...c, _collection: 'drawings' })),
    ...(await getCollection('cooking')).map(c => ({ ...c, _collection: 'cooking' })),
  ];

  const tagMap = new Map<string, typeof all>();
  for (const item of all) {
    const tag = item.data.tag;
    if (!tag) continue;
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(item);
  }

  return [...tagMap.entries()].map(([tag, items]) => ({
    params: { tag },
    props: { tag, items },
  }));
}

const { tag, items } = Astro.props;
const iconMap: Record<string, string> = {
  games: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" style="display:inline-block;vertical-align:-0.15em;color:currentColor;"><rect x="2" y="5" width="12" height="8" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="5" y="7" width="2" height="1" fill="currentColor"/><rect x="6" y="6" width="1" height="3" fill="currentColor"/><rect x="10" y="7" width="1" height="1" fill="currentColor"/><rect x="12" y="7" width="1" height="1" fill="currentColor"/><rect x="11" y="6" width="1" height="1" fill="currentColor"/><rect x="11" y="8" width="1" height="1" fill="currentColor"/></svg>',
  explorations: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" style="display:inline-block;vertical-align:-0.15em;color:currentColor;"><circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><ellipse cx="8" cy="8" rx="3" ry="6" fill="none" stroke="currentColor" stroke-width="1"/><line x1="2" y1="8" x2="14" y2="8" stroke="currentColor" stroke-width="1"/></svg>',
  crafts: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" style="display:inline-block;vertical-align:-0.15em;color:currentColor;"><circle cx="5" cy="12" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="11" cy="12" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="6.5" y1="10.5" x2="11" y2="3" stroke="currentColor" stroke-width="1.5"/><line x1="9.5" y1="10.5" x2="5" y2="3" stroke="currentColor" stroke-width="1.5"/></svg>',
  drawings: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" style="display:inline-block;vertical-align:-0.15em;color:currentColor;"><path d="M8 2C4.5 2 2 5 2 8c0 3 2 6 6 6 1 0 1.5-0.5 1.5-1s-0.3-0.8-0.5-1.2c-0.2-0.4-0.5-0.8-0.5-1.3 0-0.8 0.7-1.5 1.5-1.5h1.5c2.5 0 4.5-2 4.5-4.5C16 2.5 12.5 2 8 2z" fill="none" stroke="currentColor" stroke-width="1.5"/><rect x="5" y="5" width="1.5" height="1.5" rx="0.75" fill="currentColor"/><rect x="8" y="4" width="1.5" height="1.5" rx="0.75" fill="currentColor"/><rect x="11" y="5.5" width="1.5" height="1.5" rx="0.75" fill="currentColor"/></svg>',
  cooking: '<svg viewBox="0 0 16 16" width="16" height="16" fill="none" style="display:inline-block;vertical-align:-0.15em;color:currentColor;"><circle cx="7" cy="8" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="12" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>',
};
---

<Base title={`#${tag}`}>
  <section style="padding: 20px 0; max-width: 700px;">
    <h2 class="section-title">
      <PixelIcon name="tag" size={20} /> #{tag}
      <span style="font-size: 12px; color: var(--text-dim); font-family: var(--mono-font); margin-left: auto;">{items.length} 篇</span>
    </h2>

    <div style="display: flex; flex-direction: column; gap: 2px;">
      {items.map((item: any) => (
        <a href={`/${item._collection}/${item.id}`} class="recent-item" style="text-decoration: none;">
          <span class="recent-icon" set:html={iconMap[item._collection] || ''} />
          <span class="recent-title">{item.data.title}</span>
          <span class="recent-date">{item.data.date || ''}</span>
        </a>
      ))}
    </div>

    <div style="margin-top: 48px;">
      <a href="/" style="font-family: var(--pixel-font); font-size: 13px; color: var(--text-dim); text-decoration: none;">← BACK TO HOME</a>
    </div>
  </section>
</Base>
