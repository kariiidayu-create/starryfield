---
import Base from '../layouts/Base.astro';
import PixelIcon from '../components/PixelIcon.astro';
import { getCollection } from 'astro:content';

const allCooking = await getCollection('cooking');
const dishes = allCooking.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Base title="美食烹饪">
  <section style="padding: 20px 0;">
    <h2 class="section-title">
      <PixelIcon name="cooking" size={20} /> 美食烹饪
    </h2>
    <p style="font-size: 14px; color: var(--text-dim); margin-bottom: 32px; font-family: var(--mono-font);">
      > cook --with-love ./recipes/*
    </p>

    <div class="cooking-grid">
      {dishes.map(dish => (
        <a href={`/cooking/${dish.id}`} class="cooking-card" style="text-decoration: none;">
          <div class="cooking-card-img-wrap">
            <img class="cooking-card-img" src={dish.data.cover} alt={dish.data.title} />
            <div class="cooking-card-overlay">
              <span class="cooking-card-tag">{dish.data.tag}</span>
            </div>
          </div>
          <div class="cooking-card-body">
            <div class="cooking-card-title">{dish.data.title}</div>
            <p class="cooking-card-note">{dish.data.note}</p>
            <span class="cooking-card-date">{dish.data.date}</span>
          </div>
        </a>
      ))}
    </div>

    <p style="font-family: var(--pixel-font); font-size: 13px; color: var(--text-dim); text-align: center; margin-top: 40px;">
      // 更多美味制作中...
    </p>
  </section>

  <style>
    .cooking-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 20px;
      margin-bottom: 48px;
    }

    .cooking-card {
      background: var(--bg-card);
      border: 1px solid rgba(0, 255, 245, 0.1);
      border-radius: 2px;
      overflow: hidden;
      transition: all 0.3s;
      cursor: pointer;
    }

    .cooking-card:hover {
      border-color: var(--green);
      box-shadow: 0 0 10px rgba(57, 255, 20, 0.5), 0 0 40px rgba(57, 255, 20, 0.15);
      transform: translateY(-4px);
    }

    .cooking-card-img-wrap {
      position: relative;
      overflow: hidden;
    }

    .cooking-card-img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      transition: transform 0.4s;
    }

    .cooking-card:hover .cooking-card-img {
      transform: scale(1.05);
    }

    .cooking-card-overlay {
      position: absolute;
      top: 12px;
      left: 12px;
    }

    .cooking-card-tag {
      font-family: var(--pixel-font);
      font-size: 14px;
      color: var(--green);
      background: rgba(10, 10, 15, 0.8);
      padding: 4px 10px;
      border: 1px solid rgba(57, 255, 20, 0.3);
      border-radius: 2px;
    }

    .cooking-card-body {
      padding: 16px;
      border-top: 1px solid rgba(0, 255, 245, 0.1);
    }

    .cooking-card-title {
      font-family: var(--pixel-font);
      font-size: 13px;
      color: var(--text);
      margin-bottom: 8px;
      line-height: 1.6;
    }

    .cooking-card-note {
      font-size: 13px;
      color: var(--text-dim);
      line-height: 1.6;
      margin-bottom: 8px;
    }

    .cooking-card-date {
      font-family: var(--mono-font);
      font-size: 13px;
      color: var(--text-dim);
      opacity: 0.6;
    }

    @media (max-width: 640px) {
      .cooking-grid { grid-template-columns: 1fr; }
    }
  </style>
</Base>
