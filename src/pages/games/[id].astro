---
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments.astro';
import Reactions from '../../components/Reactions.astro';
import Share from '../../components/Share.astro';
import TOC from '../../components/TOC.astro';
import ScrollTimeline from '../../components/interactions/ScrollTimeline.astro';
import { getCollection, render } from 'astro:content';
import { getReadingTime } from '../../utils/reading-time';

export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map(game => ({ params: { id: game.id }, props: { game } }));
}

const { game } = Astro.props;
const { Content, headings } = await render(game);
const readingTime = getReadingTime(game.body || '');
const interaction = game.data.interaction;
---

<Base title={game.data.title}>
  <div class={`article-layout ${interaction === 'scroll-timeline' ? 'scroll-timeline' : ''}`}>
    <article style="padding: 20px 0; max-width: 700px; flex: 1; min-width: 0;">
      <div class="post-header">
        <div class="post-meta" style="margin-bottom: 16px;">
          <span class="tag">{game.data.tag}</span>
          <span>{game.data.platform}</span>
          {game.data.rating && <span style="color: var(--cyan);">{game.data.rating}</span>}
          <span class="reading-time">约 {readingTime} 分钟</span>
        </div>
        <h1 class="post-title">{game.data.title}</h1>
        <p style="font-size: 15px; color: var(--text-dim); margin-top: 8px; font-style: italic;">{game.data.note}</p>
      </div>
      <div class="post-content" style="margin-top: 32px;">
        <Content />
      </div>
      <Share title={game.data.title} />
      <Reactions />
      <Comments />
      <div style="margin-top: 48px; padding-top: 24px; border-top: 1px dashed rgba(0,255,245,0.15);">
        <a href="/games" style="font-family: var(--pixel-font); font-size: 13px; color: var(--text-dim); text-decoration: none;">← BACK TO GAMES</a>
      </div>
    </article>
    <TOC headings={headings} />
  </div>
  {interaction === 'scroll-timeline' && <ScrollTimeline />}
</Base>
