---
import Base from '../layouts/Base.astro';
import PixelIcon from '../components/PixelIcon.astro';
---

<Base title="留言板">
  <section style="padding: 20px 0;">
    <h2 class="section-title">
      <PixelIcon name="comment" size={20} /> 留言板
    </h2>
    <p style="font-size: 14px; color: var(--text-dim); margin-bottom: 16px; font-family: var(--mono-font);">
      > echo "说点什么吧~"
    </p>
    <details style="font-size: 13px; color: var(--text-dim); margin-bottom: 32px; font-family: var(--mono-font);">
      <summary style="cursor: pointer; color: var(--cyan); font-size: 12px;">// TIP: 如何获得评论头像？</summary>
      <div style="margin-top: 8px; padding-left: 16px; line-height: 1.8;">
        1. 前往 <a href="https://gravatar.com" target="_blank" rel="noopener">gravatar.com</a> 注册（用你留言时填的邮箱）<br />
        2. 上传你想要的头像<br />
        3. 之后用这个邮箱留言就会自动显示头像
      </div>
    </details>

    <div id="twikoo-comment"></div>
  </section>

  <script is:inline src="https://registry.npmmirror.com/twikoo/1.6.40/files/dist/twikoo.all.min.js"></script>
  <script is:inline>
    twikoo.init({
      envId: 'https://twikoo.starryfield.space',
      el: '#twikoo-comment',
      lang: 'zh-CN',
      placeholder: '留下你划过这片星空的痕迹吧～',
    });
  </script>

  <style>
    /* Twikoo 样式覆盖，适配赛博主题 */
    :global(.tk-comments) {
      --tk-color: var(--text) !important;
      --tk-main-color: var(--cyan) !important;
      --tk-meta-color: var(--text-dim) !important;
    }
    :global(.tk-input) {
      background: var(--bg-card) !important;
      border: 1px solid rgba(0, 255, 245, 0.2) !important;
      color: var(--text) !important;
      border-radius: 2px !important;
    }
    :global(.tk-input:focus) {
      border-color: var(--cyan) !important;
      box-shadow: var(--glow-cyan) !important;
    }
    :global(.tk-submit .tk-btn) {
      background: transparent !important;
      border: 1px solid var(--cyan) !important;
      color: var(--cyan) !important;
      border-radius: 2px !important;
      font-family: var(--pixel-font) !important;
      font-size: 13px !important;
    }
    :global(.tk-submit .tk-btn:hover) {
      background: rgba(0, 255, 245, 0.1) !important;
      box-shadow: var(--glow-cyan) !important;
    }
    :global(.tk-content) {
      color: var(--text) !important;
    }
    :global(.tk-nick),
    :global(.tk-time) {
      color: var(--text-dim) !important;
    }
    :global(.tk-comment) {
      border-bottom: 1px solid rgba(0, 255, 245, 0.08) !important;
    }
    :global(.tk-extras) {
      color: var(--text-dim) !important;
    }
  </style>
</Base>
