---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth <= 3);
---

{filtered.length > 2 && (
  <nav class="toc">
    <div class="toc-title">目录</div>
    <div class="toc-timeline">
      {filtered.map(h => (
        <a href={`#${h.slug}`} class={`toc-node toc-h${h.depth}`}>
          <div class="toc-dot"></div>
          <span class="toc-text">{h.text}</span>
        </a>
      ))}
    </div>
  </nav>
)}

<style>
  .toc {
    position: sticky;
    top: 24px;
    width: 200px;
    flex-shrink: 0;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    padding: 16px 16px 16px 0;
  }

  .toc-title {
    font-family: var(--pixel-font);
    font-size: 11px;
    color: var(--cyan);
    text-shadow: var(--glow-cyan);
    margin-bottom: 16px;
    margin-left: 20px;
  }

  .toc-timeline {
    position: relative;
    padding-left: 20px;
  }

  .toc-timeline::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--cyan), var(--magenta), transparent);
    opacity: 0.25;
  }

  .toc-node {
    position: relative;
    display: block;
    text-decoration: none;
    padding: 6px 0;
  }

  .toc-dot {
    position: absolute;
    left: -19px;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid rgba(0, 255, 245, 0.3);
    transition: all 0.3s ease;
    z-index: 1;
  }

  .toc-node:hover .toc-dot,
  .toc-node.active .toc-dot {
    background: var(--cyan);
    border-color: var(--cyan);
    box-shadow: 0 0 8px rgba(0, 255, 245, 0.5);
  }

  .toc-text {
    font-family: var(--mono-font);
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.5;
    transition: color 0.2s;
  }

  .toc-node:hover .toc-text,
  .toc-node.active .toc-text {
    color: var(--cyan);
  }

  .toc-h3 {
    padding-left: 14px;
  }

  .toc-h3 .toc-dot {
    width: 6px;
    height: 6px;
    border-width: 1.5px;
  }

  @media (max-width: 900px) {
    .toc {
      display: none;
    }
  }
</style>

<script>
  const tocNodes = document.querySelectorAll('.toc-node');
  if (tocNodes.length > 0) {
    const headingEls = Array.from(tocNodes).map(node => {
      const id = node.getAttribute('href')?.slice(1);
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          tocNodes.forEach(n => n.classList.remove('active'));
          const active = document.querySelector(`.toc-node[href="#${entry.target.id}"]`);
          active?.classList.add('active');
        }
      }
    }, { rootMargin: '-80px 0px -60% 0px' });

    headingEls.forEach(el => observer.observe(el));
  }
</script>
