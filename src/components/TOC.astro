---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth <= 3);
---

{filtered.length > 2 && (
  <nav class="toc">
    <div class="toc-title">目录</div>
    <ul class="toc-list">
      {filtered.map(h => (
        <li class={`toc-item toc-h${h.depth}`}>
          <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc {
    position: sticky;
    top: 24px;
    width: 200px;
    flex-shrink: 0;
    max-height: calc(100vh - 48px);
    overflow-y: auto;
    padding: 16px;
    background: var(--bg-card);
    border: 1px solid rgba(0, 255, 245, 0.1);
    border-radius: 2px;
  }

  .toc-title {
    font-family: var(--pixel-font);
    font-size: 11px;
    color: var(--cyan);
    text-shadow: var(--glow-cyan);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px dashed rgba(0, 255, 245, 0.15);
  }

  .toc-list {
    list-style: none;
    padding: 0;
  }

  .toc-item {
    margin-bottom: 4px;
  }

  .toc-h3 {
    padding-left: 12px;
  }

  .toc-link {
    font-family: var(--mono-font);
    font-size: 12px;
    color: var(--text-dim);
    text-decoration: none;
    display: block;
    padding: 4px 0;
    transition: color 0.2s;
    line-height: 1.5;
  }

  .toc-link:hover,
  .toc-link.active {
    color: var(--cyan);
  }

  @media (max-width: 900px) {
    .toc {
      display: none;
    }
  }
</style>

<script>
  const tocLinks = document.querySelectorAll('.toc-link');
  if (tocLinks.length > 0) {
    const headingEls = Array.from(tocLinks).map(link => {
      const id = link.getAttribute('href')?.slice(1);
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
          active?.classList.add('active');
        }
      }
    }, { rootMargin: '-80px 0px -60% 0px' });

    headingEls.forEach(el => observer.observe(el));
  }
</script>
