---
interface Props {
  name: string;
  size?: number;
}

const { name, size = 16 } = Astro.props;

// All icons are 16x16 pixel grids drawn with rects
const icons: Record<string, string> = {
  // 🎮 Gamepad
  gamepad: `<rect x="2" y="5" width="12" height="8" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <rect x="5" y="7" width="2" height="1" fill="currentColor"/><rect x="6" y="6" width="1" height="3" fill="currentColor"/>
    <rect x="10" y="7" width="1" height="1" fill="currentColor"/><rect x="12" y="7" width="1" height="1" fill="currentColor"/><rect x="11" y="6" width="1" height="1" fill="currentColor"/><rect x="11" y="8" width="1" height="1" fill="currentColor"/>`,

  // 🌍 Globe
  globe: `<circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <ellipse cx="8" cy="8" rx="3" ry="6" fill="none" stroke="currentColor" stroke-width="1"/>
    <line x1="2" y1="8" x2="14" y2="8" stroke="currentColor" stroke-width="1"/>
    <line x1="3" y1="5" x2="13" y2="5" stroke="currentColor" stroke-width="0.8"/>
    <line x1="3" y1="11" x2="13" y2="11" stroke="currentColor" stroke-width="0.8"/>`,

  // ✂️ Scissors
  scissors: `<circle cx="5" cy="12" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="11" cy="12" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <line x1="6.5" y1="10.5" x2="11" y2="3" stroke="currentColor" stroke-width="1.5"/>
    <line x1="9.5" y1="10.5" x2="5" y2="3" stroke="currentColor" stroke-width="1.5"/>`,

  // 🎨 Palette
  palette: `<path d="M8 2C4.5 2 2 5 2 8c0 3 2 6 6 6 1 0 1.5-0.5 1.5-1s-0.3-0.8-0.5-1.2c-0.2-0.4-0.5-0.8-0.5-1.3 0-0.8 0.7-1.5 1.5-1.5h1.5c2.5 0 4.5-2 4.5-4.5C16 2.5 12.5 2 8 2z" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <rect x="5" y="5" width="1.5" height="1.5" rx="0.75" fill="currentColor"/>
    <rect x="8" y="4" width="1.5" height="1.5" rx="0.75" fill="currentColor"/>
    <rect x="11" y="5.5" width="1.5" height="1.5" rx="0.75" fill="currentColor"/>
    <rect x="4" y="8" width="1.5" height="1.5" rx="0.75" fill="currentColor"/>`,

  // 🍳 Pan
  cooking: `<circle cx="7" cy="8" r="5" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <line x1="12" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <circle cx="6" cy="7" r="1" fill="currentColor" opacity="0.6"/>
    <circle cx="8" cy="9" r="0.8" fill="currentColor" opacity="0.6"/>`,

  // 📊 Chart
  chart: `<rect x="2" y="9" width="3" height="5" fill="currentColor" opacity="0.6"/>
    <rect x="6.5" y="5" width="3" height="9" fill="currentColor" opacity="0.8"/>
    <rect x="11" y="2" width="3" height="12" fill="currentColor"/>
    <line x1="1" y1="14.5" x2="15" y2="14.5" stroke="currentColor" stroke-width="1"/>`,

  // 🛸 UFO
  ufo: `<ellipse cx="8" cy="9" rx="6" ry="2" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <path d="M5 9 Q5 4 8 4 Q11 4 11 9" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <rect x="7" y="3" width="2" height="1" fill="currentColor"/>
    <line x1="4" y1="11" x2="3" y2="13" stroke="currentColor" stroke-width="1" opacity="0.5"/>
    <line x1="12" y1="11" x2="13" y2="13" stroke="currentColor" stroke-width="1" opacity="0.5"/>
    <line x1="8" y1="11" x2="8" y2="13" stroke="currentColor" stroke-width="1" opacity="0.5"/>`,

  // 📡 Satellite dish
  satellite: `<path d="M3 13 L7 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M4 7 Q8 3 13 4" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <path d="M5 9.5 Q8 6 12 6.5" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.6"/>
    <circle cx="3" cy="13" r="1" fill="currentColor"/>
    <rect x="12" y="2" width="2" height="2" fill="currentColor" opacity="0.8"/>`,

  // ⚡ Lightning
  lightning: `<polygon points="9,1 4,9 8,9 7,15 12,7 8,7" fill="currentColor"/>`,

  // 🏷️ Tag
  tag: `<path d="M2 3 L9 3 L14 8 L9 13 L2 13 Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    <circle cx="5" cy="8" r="1.2" fill="currentColor"/>`,

  // 📷 Camera
  camera: `<rect x="2" y="5" width="12" height="8" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="8" cy="9" r="2.5" fill="none" stroke="currentColor" stroke-width="1.2"/>
    <rect x="5" y="3" width="4" height="2" fill="currentColor" opacity="0.6"/>
    <rect x="12" y="6" width="1" height="1" fill="currentColor"/>`,

  // 🔖 Bookmark
  bookmark: `<path d="M4 2 L12 2 L12 14 L8 11 L4 14 Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,

  // 💬 Comment bubble
  comment: `<path d="M2 3 L14 3 L14 10 L7 10 L4 13 L4 10 L2 10 Z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    <line x1="5" y1="6" x2="11" y2="6" stroke="currentColor" stroke-width="1" opacity="0.6"/>
    <line x1="5" y1="8" x2="9" y2="8" stroke="currentColor" stroke-width="1" opacity="0.6"/>`,

  // ✦ Star
  star: `<polygon points="8,1 9.8,6 15,6.5 11,10 12.5,15 8,12 3.5,15 5,10 1,6.5 6.2,6" fill="currentColor"/>`,

  // 🔧 Wrench
  wrench: `<path d="M12 2 Q15 5 12 8 L6 14 Q4 16 2 14 Q0 12 2 10 L8 4 Q5 1 8 -1 Z" fill="none" stroke="currentColor" stroke-width="1.2" transform="scale(0.9) translate(1,1)"/>`,

  // ⏱ Timer
  timer: `<circle cx="8" cy="9" r="5.5" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <line x1="8" y1="9" x2="8" y2="6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="8" y1="9" x2="10.5" y2="9" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <rect x="7" y="2" width="2" height="1.5" fill="currentColor"/>`,

  // 📍 Pin
  pin: `<path d="M8 1 Q13 1 13 6 Q13 10 8 15 Q3 10 3 6 Q3 1 8 1 Z" fill="none" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="8" cy="6" r="2" fill="currentColor" opacity="0.6"/>`,

  // ☀️ Sun
  sun: `<circle cx="8" cy="8" r="3" fill="currentColor"/>
    <line x1="8" y1="1" x2="8" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="8" y1="13" x2="8" y2="15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="1" y1="8" x2="3" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="13" y1="8" x2="15" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="3" y1="3" x2="4.5" y2="4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="11.5" y1="11.5" x2="13" y2="13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="3" y1="13" x2="4.5" y2="11.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
    <line x1="11.5" y1="4.5" x2="13" y2="3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>`,

  // 🌙 Moon
  moon: `<path d="M10 2 Q6 2 4 5 Q2 8 4 11 Q6 14 10 14 Q7 12 7 8 Q7 4 10 2 Z" fill="currentColor"/>`,

  // ⚠️ Warning
  warning: `<polygon points="8,1 15,14 1,14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
    <line x1="8" y1="5.5" x2="8" y2="9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    <rect x="7.3" y="11" width="1.4" height="1.4" fill="currentColor"/>`,
};

const svg = icons[name] || icons['star'];
---

<svg class="px-icon" viewBox="0 0 16 16" width={size} height={size} fill="none" aria-hidden="true" set:html={svg} />

<style>
  .px-icon {
    display: inline-block;
    vertical-align: -0.15em;
    color: currentColor;
    image-rendering: pixelated;
    flex-shrink: 0;
  }
</style>
