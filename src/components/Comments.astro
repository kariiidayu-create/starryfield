---
import PixelIcon from './PixelIcon.astro';
---
<!-- Twikoo 评论区 -->
<section class="comments-section">
  <h3 class="section-title" style="font-size: 14px;">
    <PixelIcon name="comment" size={20} /> 评论
  </h3>
  <div id="twikoo-comment"></div>
</section>

<script is:inline src="https://registry.npmmirror.com/twikoo/1.6.40/files/dist/twikoo.all.min.js"></script>
<script is:inline>
  twikoo.init({
    envId: 'https://twikoo.starryfield.space',
    el: '#twikoo-comment',
    lang: 'zh-CN',
  });
</script>

<style>
  .comments-section {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px dashed rgba(0, 255, 245, 0.15);
  }
  :global(.comments-section .tk-comments) {
    --tk-color: var(--text) !important;
    --tk-main-color: var(--cyan) !important;
    --tk-meta-color: var(--text-dim) !important;
  }
  :global(.comments-section .tk-input) {
    background: var(--bg-card) !important;
    border: 1px solid rgba(0, 255, 245, 0.2) !important;
    color: var(--text) !important;
    border-radius: 2px !important;
  }
  :global(.comments-section .tk-input:focus) {
    border-color: var(--cyan) !important;
    box-shadow: var(--glow-cyan) !important;
  }
  :global(.comments-section .tk-submit .tk-btn) {
    background: transparent !important;
    border: 1px solid var(--cyan) !important;
    color: var(--cyan) !important;
    border-radius: 2px !important;
    font-family: var(--pixel-font) !important;
    font-size: 13px !important;
  }
  :global(.comments-section .tk-submit .tk-btn:hover) {
    background: rgba(0, 255, 245, 0.1) !important;
    box-shadow: var(--glow-cyan) !important;
  }
  :global(.comments-section .tk-content) {
    color: var(--text) !important;
  }
  :global(.comments-section .tk-nick),
  :global(.comments-section .tk-time) {
    color: var(--text-dim) !important;
  }
  :global(.comments-section .tk-comment) {
    border-bottom: 1px solid rgba(0, 255, 245, 0.08) !important;
  }
</style>
